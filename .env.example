# 项目唯一环境配置：在此配置后，网关与前端会统一使用。
# 复制为 .env 并修改。

# Ollama 模型名，如：deepseek-r1:8b、qwen2.5-coder:7b
OLLAMA_MODEL=deepseek-r1:8b

# 可选：网关端口，默认 3000
# PORT=3000

# 可选：Ollama 服务地址，默认 http://127.0.0.1:11434
# OLLAMA_HOST=http://127.0.0.1:11434

# 可选：跨对话记忆与人设（路径与条数/字符上限见 gateway/README.md）
# MEMORY_PATH= PERSONA_PATH=

# 可选：当前时间来源。不设或设为 1/true/yes = 用网络时间（WorldTimeAPI），分钟更准；设为 0/false/no = 用本机时钟（内网或无外网时）
# USE_EXTERNAL_TIME=1

# 可选：访问外网时的代理（如翻墙）。网关内 Playwright（BROWSER_NAVIGATE）、FETCH_URL 等会使用
# HTTP_PROXY=http://127.0.0.1:7897
# HTTPS_PROXY=http://127.0.0.1:7897

# 可选：本地文件操作根目录。大模型 READ_FILE/WRITE_FILE/LIST_DIR 仅能访问此目录及子目录；禁止 ..、绝对路径、越界与符号链接逃逸
# 示例：桌面下 work 文件夹（请改为本机实际路径）
# LOCAL_FILE_ROOT=/Users/你的用户名/Desktop/work
