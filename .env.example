# 项目唯一环境配置：在此配置后，网关与前端会统一使用。
# 复制为 .env 并修改。

# Ollama 模型名，如：deepseek-r1:8b、qwen2.5-coder:7b
OLLAMA_MODEL=deepseek-r1:8b

# 可选：网关端口，默认 3000
# PORT=3000

# 可选：Ollama 服务地址，默认 http://127.0.0.1:11434
# OLLAMA_HOST=http://127.0.0.1:11434

# 可选：跨对话记忆与人设（路径与条数/字符上限见 gateway/README.md）
# MEMORY_PATH= PERSONA_PATH=
